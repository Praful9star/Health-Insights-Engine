modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["resend:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 19109
externalPort = 3003

[[ports]]
localPort = 25201
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
SANITY_PROJECT_ID = "tqmjf1jn"
SANITY_DATASET = "production"
RAZORPAY_PREMIUM_MONTHLY_LINK = "https://rzp.io/rzp/jywNeGo"
RAZORPAY_PREMIUM_ANNUAL_LINK = "https://rzp.io/rzp/y4J1B3a"
